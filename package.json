{
  "name": "victron-tcp",
  "version": "1.1.1",
  "description": "MCP server for Victron Energy GX devices via Modbus TCP or MQTT",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "victron-tcp": "dist/index.js"
  },
  "files": [
    "dist",
    "data",
    "docs/register-list.md",
    "docs/vrm-api-openapi.yaml",
    "server.json",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "convert": "tsx scripts/convert-excel.ts",
    "simulate": "tsx scripts/modbus-simulator.ts",
    "test": "vitest run",
    "inspect": "npx @modelcontextprotocol/inspector node dist/index.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "victron",
    "modbus",
    "mqtt",
    "mcp",
    "model-context-protocol",
    "energy",
    "solar",
    "battery",
    "inverter",
    "venus-os"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/lubosstrejcek/victron-tcp.git"
  },
  "homepage": "https://github.com/lubosstrejcek/victron-tcp",
  "author": "Lubos Strejcek",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.28.0",
    "modbus-serial": "^8.0.23",
    "mqtt": "^5.15.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.0.18"
  }
}
